<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Velvet Grid — Rhythm Stage</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;700;800&family=Rajdhani:wght@500;600;700&display=swap');
        :root {
            --bg-0: #140810;
            --bg-1: #1d0d18;
            --bg-2: #2a1320;
            --panel: rgba(35,14,25,0.78);
            --panel-soft: rgba(255,240,231,0.06);
            --line: rgba(255,232,217,0.16);
            --line-strong: rgba(255,196,143,0.36);
            --rose: #ff8fb1;
            --champagne: #ffd7a8;
            --violet: #c6a3ff;
            --cyan: #84f1ff;
            --amber: #ffb86b;
            --danger: #ff6f88;
            --text: #fff6ef;
            --muted: rgba(255,239,228,0.72);
        }
        *,*::before,*::after { box-sizing:border-box; }
        body {
            margin:0; overflow:hidden;
            background:
                radial-gradient(circle at 14% 12%, rgba(255,172,121,.16), transparent 20%),
                radial-gradient(circle at 84% 16%, rgba(198,163,255,.16), transparent 24%),
                radial-gradient(circle at 50% 100%, rgba(255,143,177,.14), transparent 26%),
                linear-gradient(180deg,#12070d,#1a0b15 42%,#090307);
            font-family:'Manrope',sans-serif;
            color:var(--text);
        }
        #backgroundCanvas { position:fixed; top:0; left:0; z-index:0; pointer-events:none; }
        #gameCanvas       { position:fixed; top:0; left:0; z-index:1; }
        .hidden { display:none !important; }

        /* ── Loading / waiting overlay ────────────────────────────────────── */
        #loadingOverlay {
            position:fixed; inset:0; z-index:10;
            display:flex; flex-direction:column;
            align-items:center; justify-content:center;
            gap:0;
            background:
                radial-gradient(circle at 50% 38%, rgba(198,163,255,.10), transparent 55%),
                linear-gradient(180deg,#0d0611,#160a18 55%,#0b0510);
            pointer-events:none;
            opacity:0;
            transition:opacity .4s;
        }
        #loadingOverlay.visible { opacity:1; pointer-events:auto; }

        /* Floating particles canvas behind overlay content */
        #waitCanvas { position:absolute; inset:0; z-index:0; pointer-events:none; }

        .wait-inner {
            position:relative; z-index:1;
            display:flex; flex-direction:column; align-items:center;
            gap:18px; padding:0 24px; text-align:center;
        }
        .wait-logo {
            font:700 11px 'Rajdhani',sans-serif;
            letter-spacing:.28em; text-transform:uppercase;
            color:rgba(198,163,255,.55);
            margin-bottom:4px;
        }
        .wait-title {
            font:700 42px 'Cormorant Garamond',serif;
            color:#f6eeff;
            text-shadow:0 0 48px rgba(198,163,255,.35);
            line-height:1;
        }
        .wait-sub {
            font:600 14px 'Rajdhani',sans-serif;
            letter-spacing:.12em; text-transform:uppercase;
            color:rgba(255,183,120,.72);
            max-width:38ch;
        }
        .wait-bar-wrap {
            width:260px; height:3px; border-radius:99px;
            background:rgba(255,255,255,.08);
            overflow:hidden;
        }
        .wait-bar-fill {
            height:100%; border-radius:99px; width:0%;
            background:linear-gradient(90deg,var(--violet),var(--cyan));
            box-shadow:0 0 14px rgba(198,163,255,.55);
            transition:width .35s ease;
        }
        .wait-status {
            font:500 13px 'Rajdhani',sans-serif;
            letter-spacing:.06em;
            color:rgba(228,241,248,.52);
            min-height:20px;
        }
        .wait-hint {
            margin-top:8px;
            font:600 12px 'Rajdhani',sans-serif;
            letter-spacing:.14em; text-transform:uppercase;
            color:rgba(198,163,255,.36);
        }
        /* click ripple */
        .wait-ripple {
            position:absolute; border-radius:50%;
            width:0; height:0; pointer-events:none;
            border:1.5px solid rgba(198,163,255,.6);
            transform:translate(-50%,-50%);
            animation:rippleOut .7s ease-out forwards;
        }
        @keyframes rippleOut {
            to { width:180px; height:180px; opacity:0; border-color:rgba(198,163,255,0); }
        }

        /* ── HUD ──────────────────────────────────────────────────────────── */
        #score {
            position:fixed; top:18px; right:18px;
            min-width:160px; max-width:200px;
            z-index:3; text-align:right;
            padding:14px 18px;
            background:linear-gradient(180deg,rgba(12,18,28,.84),rgba(5,8,12,.7));
            border:1px solid rgba(255,255,255,.12);
            border-radius:18px;
            box-shadow:0 18px 60px rgba(0,0,0,.45),inset 0 0 18px rgba(84,241,255,.06);
            color:#fff5ec;
            font-weight:700; letter-spacing:.04em;
        }
        #score::before {
            content:''; position:absolute; inset:0;
            background:linear-gradient(130deg,rgba(198,163,255,.12),transparent 32%,transparent 68%,rgba(255,184,77,.12));
            pointer-events:none;
        }
        .hud-topline {
            position:relative; z-index:1;
            display:flex; justify-content:space-between;
            align-items:flex-start; gap:16px;
        }
        .score-stack small,.hud-module small,.score-aux small {
            display:block;
            font:700 11px 'Rajdhani',sans-serif;
            letter-spacing:.18em; text-transform:uppercase;
            color:rgba(228,241,248,.54); margin-bottom:6px;
        }
        .score-main {
            font:700 62px 'Cormorant Garamond',serif;
            line-height:.92; color:var(--text);
            text-shadow:0 0 24px rgba(255,183,120,.22);
        }
        .hud-top-actions { display:flex; align-items:flex-start; gap:10px; flex-wrap:wrap; justify-content:flex-end; }
        .score-aux { min-width:98px; text-align:right; }
        .score-aux strong { display:block; font:700 38px 'Cormorant Garamond',serif; color:#ffd9a8; line-height:1; }
        .hud-control-btn { margin-top:0; min-height:40px; min-width:88px; padding:10px 14px; font-size:12px; border-radius:12px; }
        .score-modules { position:relative; z-index:1; display:grid; grid-template-columns:repeat(auto-fit,minmax(110px,1fr)); gap:10px; margin-top:14px; }
        .hud-module { padding:11px 12px 12px; border-radius:16px; background:rgba(255,239,228,.05); border:1px solid rgba(255,255,255,.08); }
        .hud-module strong { display:block; font:700 18px 'Rajdhani',sans-serif; letter-spacing:.06em; color:var(--text); }
        .hud-module.emphasis strong { color:var(--champagne); }
        .hud-module.alert strong { color:#ffd1d7; }
        #runState[data-state="invalid"] strong { color:var(--danger); }
        .score-meter { position:relative; z-index:1; margin-top:14px; height:8px; border-radius:999px; background:rgba(255,255,255,.06); overflow:hidden; }
        .score-meter-fill { width:38%; height:100%; background:linear-gradient(90deg,var(--cyan),var(--amber)); box-shadow:0 0 24px rgba(255,183,120,.34); }
        .debug-strip { position:relative; z-index:1; margin-top:12px; display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); gap:8px; font:700 11px 'Rajdhani',sans-serif; letter-spacing:.06em; text-transform:uppercase; color:rgba(228,241,248,.72); }
        .debug-strip span { padding:8px 10px; border-radius:12px; background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.06); }
        .debug-strip b { color:#f6fdff; font-weight:700; }
        .debug-strip span.warn { border-color:rgba(255,111,136,.42); background:rgba(255,111,136,.12); }
        .debug-strip span.good { border-color:rgba(255,213,131,.34); background:rgba(255,213,131,.08); }

        /* ── Upload / setup panel ─────────────────────────────────────────── */
        #uploadContainer {
            position:fixed; top:50%; left:50%;
            transform:translate(-50%,-50%);
            z-index:2;
            background:
                linear-gradient(180deg,rgba(255,255,255,.05),rgba(255,230,218,.018)),
                linear-gradient(180deg,rgba(41,14,28,.9),rgba(23,8,16,.82));
            border:1px solid var(--line);
            border-radius:28px;
            box-shadow:0 30px 90px rgba(0,0,0,.46),inset 0 0 48px rgba(84,241,255,.04);
            backdrop-filter:blur(24px);
            min-width:820px; max-width:min(92vw,980px);
            padding:26px 28px 24px;
            overflow:hidden;
        }
        #uploadContainer::before {
            content:''; position:absolute; inset:0;
            background:
                linear-gradient(transparent calc(100% - 1px),rgba(255,255,255,.04) 0),
                linear-gradient(90deg,transparent calc(100% - 1px),rgba(255,255,255,.04) 0);
            background-size:30px 30px; opacity:.26; pointer-events:none;
        }
        #uploadContainer.hidden { display:none; }
        #uploadContainer h2 {
            color:#e9fdff; letter-spacing:.14em; text-transform:uppercase;
            font-size:30px; font-family:'Manrope',sans-serif; margin:0 0 18px;
        }
        .shell-grid {
            position:relative; z-index:1;
            display:grid; grid-template-columns:minmax(280px,1.05fr) minmax(360px,1.4fr);
            gap:18px; align-items:stretch;
        }
        .intro-panel,.control-panel {
            position:relative; border-radius:22px;
            border:1px solid rgba(255,255,255,.08);
            background:linear-gradient(180deg,rgba(255,244,237,.04),rgba(255,230,218,.018));
            padding:18px;
        }
        .intro-panel::after,.control-panel::after {
            content:''; position:absolute; left:18px; right:18px; top:0; height:1px;
            background:linear-gradient(90deg,transparent,rgba(255,183,120,.42),transparent);
        }
        .eyebrow {
            font:700 12px 'Rajdhani',sans-serif;
            letter-spacing:.2em; text-transform:uppercase;
            color:var(--amber); margin-bottom:10px;
        }

        /* changelog */
        .changelog {
            display:flex; flex-direction:column; gap:8px;
            margin-top:2px;
        }
        .cl-entry {
            display:flex; gap:10px; align-items:flex-start;
            padding:9px 11px; border-radius:14px;
            background:rgba(255,255,255,.03);
            border:1px solid rgba(255,255,255,.06);
        }
        .cl-dot {
            flex-shrink:0; margin-top:4px;
            width:6px; height:6px; border-radius:50%;
        }
        .cl-dot.new   { background:var(--cyan);    box-shadow:0 0 8px rgba(132,241,255,.7); }
        .cl-dot.fix   { background:var(--amber);   box-shadow:0 0 8px rgba(255,184,107,.7); }
        .cl-dot.tweak { background:var(--violet);  box-shadow:0 0 8px rgba(198,163,255,.7); }
        .cl-text { font:500 12px 'Rajdhani',sans-serif; letter-spacing:.04em; color:var(--muted); line-height:1.5; }
        .cl-text b { font-weight:700; color:var(--text); }
        .cl-badge {
            display:inline-block; margin-left:6px;
            font:700 10px 'Rajdhani',sans-serif; letter-spacing:.08em; text-transform:uppercase;
            padding:1px 6px; border-radius:6px; vertical-align:middle;
        }
        .cl-badge.new   { background:rgba(132,241,255,.14); color:var(--cyan);   border:1px solid rgba(132,241,255,.28); }
        .cl-badge.fix   { background:rgba(255,184,107,.12); color:var(--amber);  border:1px solid rgba(255,184,107,.24); }
        .cl-badge.tweak { background:rgba(198,163,255,.12); color:var(--violet); border:1px solid rgba(198,163,255,.24); }

        /* controls */
        .control-grid { display:grid; gap:12px; }
        .control-row { display:flex; gap:10px; align-items:center; justify-content:center; flex-wrap:wrap; }
        .control-row.actions { margin-top:4px; }
        .control-row .wide { flex:1 1 320px; }
        .control-row > * { min-width:0; }
        .status-panel { margin-top:14px; padding:14px; border-radius:18px; border:1px solid rgba(255,255,255,.08); background:rgba(0,0,0,.24); }

        /* inputs */
        #youtubeUrl,#difficultySelect,#playModeSelect,#analysisStrategySelect,#chartDensitySelect {
            box-shadow:inset 0 0 0 1px rgba(255,255,255,.04),0 0 0 1px rgba(255,183,120,.10);
            background:rgba(44,18,30,.84) !important;
            color:var(--text);
            border:1px solid rgba(255,255,255,.12) !important;
            border-radius:14px !important;
            min-height:46px;
            font:600 14px 'Rajdhani',sans-serif;
            letter-spacing:.05em;
        }
        #youtubeUrl::placeholder { color:rgba(228,241,248,.46); }

        /* buttons */
        button {
            padding:10px 20px;
            background:linear-gradient(180deg,#6f2b49,#321423);
            border:1px solid rgba(255,255,255,.14);
            border-radius:14px;
            box-shadow:0 10px 24px rgba(0,0,0,.28),inset 0 0 18px rgba(255,183,120,.06);
            font:700 14px 'Rajdhani',sans-serif;
            letter-spacing:.08em; text-transform:uppercase;
            color:#fff; cursor:pointer;
            min-height:46px; margin-top:15px; font-size:16px;
            transition:all .2s;
        }
        button:hover { background:linear-gradient(180deg,#8b3759,#45182d); transform:translateY(-1px); }
        button:disabled { background:#333; cursor:not-allowed; opacity:.6; }

        .file-upload { position:relative; display:inline-block; margin:10px; }
        .file-upload-btn {
            display:inline-block; padding:8px 16px;
            background:#8f3657; border:1px solid #ffb56b;
            border-radius:4px; color:#fff; cursor:pointer;
            transition:all .3s; box-shadow:0 2px 5px rgba(0,0,0,.3);
        }
        .file-upload-btn:hover { background:#ffb56b; box-shadow:0 3px 7px rgba(0,0,0,.5); }
        .file-upload input[type="file"] { position:absolute; left:0; top:0; opacity:0; width:100%; height:100%; cursor:pointer; }

        .info-message,.note-message,.loading-message,.success-message,.error-message { border-radius:14px; }
        .info-message    { color:#fff; background:rgba(0,0,0,.5); padding:8px; border-radius:4px; border:1px solid rgba(255,255,255,.2); margin-top:10px; }
        .success-message { color:#ffb56b; padding:10px; background:rgba(13,111,28,.15); border-radius:5px; border:1px solid rgba(255,183,120,.24); }
        .error-message   { color:#ff8ba7; padding:10px; background:rgba(255,111,136,.14); border-radius:5px; border:1px solid rgba(255,111,136,.28); }
        .loading-message { color:#e0e0e0; padding:10px; background:rgba(255,255,255,.1); border-radius:5px; border:1px solid rgba(255,255,255,.2); }
        .note-message    { color:#ffb56b; background:rgba(13,111,28,.1); padding:8px; border-radius:4px; border:1px solid rgba(25,163,54,.2); margin-top:10px; }

        /* pause overlay */
        #pauseOverlay {
            position:fixed; inset:0; z-index:4;
            display:flex; align-items:center; justify-content:center;
            flex-direction:column; gap:12px; font-size:22px;
            background:
                radial-gradient(circle at 50% 50%,rgba(255,183,120,.10),transparent 20%),
                linear-gradient(180deg,rgba(4,7,13,.92),rgba(2,4,9,.94));
            backdrop-filter:blur(18px);
        }
        #pauseOverlayText { font-size:46px; letter-spacing:.08em; text-transform:uppercase; color:#f5fdff; text-shadow:0 0 26px rgba(198,163,255,.24); }
        #pauseOverlaySubtext { padding:12px 16px; border-radius:14px; background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.08); }
        #overlayResumeBtn { margin-top:6px; min-width:190px; }

        #livePlayerHolder { position:fixed; left:20px; bottom:20px; z-index:3; background:rgba(0,0,0,.7); padding:10px; border:1px solid rgba(255,255,255,.2); border-radius:8px; }
        #livePlayerHolder.hidden { display:none; }
        #liveAudio { width:320px; }

        @media(max-width:1200px){
            #score { width:min(480px,calc(100vw - 24px)); max-width:calc(100vw - 24px); }
        }
        @media(max-width:940px){
            #uploadContainer { min-width:0; width:min(94vw,760px); }
            .shell-grid { grid-template-columns:1fr; }
            #score { left:12px; right:12px; top:12px; width:auto; max-width:calc(100vw - 24px); min-width:0; padding:14px; }
            .score-main { font-size:44px; }
            .score-modules { grid-template-columns:repeat(2,minmax(0,1fr)); }
            .debug-strip { grid-template-columns:repeat(2,minmax(0,1fr)); }
        }
        @media(max-width:640px){
            .hud-topline { flex-direction:column; align-items:stretch; }
            .hud-top-actions { justify-content:space-between; align-items:center; }
            .score-aux { text-align:left; }
            .score-modules,.debug-strip { grid-template-columns:1fr; }
            .score-main { font-size:38px; }
            .hud-control-btn { width:100%; }
        }
    </style>
</head>
<body>
    <canvas id="backgroundCanvas"></canvas>
    <canvas id="gameCanvas"></canvas>

    <!-- ── Waiting / loading overlay ────────────────────────────────────── -->
    <div id="loadingOverlay">
        <canvas id="waitCanvas"></canvas>
        <div class="wait-inner">
            <div class="wait-logo">Velvet Grid · Rhythm Engine</div>
            <div class="wait-title">Analysing the Stage</div>
            <div class="wait-sub" id="waitSubtext">Mapping beats &amp; building chart…</div>
            <div class="wait-bar-wrap"><div class="wait-bar-fill" id="waitBar"></div></div>
            <div class="wait-status" id="waitStatus">Initialising…</div>
            <div class="wait-hint">Click anywhere · press any key for a spark ✦</div>
        </div>
    </div>

    <!-- ── HUD ──────────────────────────────────────────────────────────── -->
    <div id="score">
        <div class="hud-topline" style="padding:6px 12px;gap:10px;align-items:center;">
            <div class="score-stack" style="min-width:auto;">
                <div class="score-main" id="scoreValue" style="font-size:32px;line-height:1;">000000</div>
            </div>
            <button id="hudPauseBtn" class="hud-control-btn" style="min-height:32px;min-width:60px;padding:6px 10px;font-size:11px;" aria-label="Pause game">Pause</button>
        </div>
        <div style="display:none;">
            <strong id="comboValue">0x</strong>
            <strong id="hudMode">CASUAL</strong>
            <strong id="hudDifficulty">NORMAL</strong>
            <strong id="hudAccuracy">--</strong>
            <div id="runState" data-state="stable"><strong id="hudRunState">STABLE</strong></div>
            <div class="score-meter"><div class="score-meter-fill" id="scoreMeterFill"></div></div>
            <div id="debugStrip" class="debug-strip hidden">
                <span>Clock <b id="debugGameClock">0.00</b></span>
                <span>Player <b id="debugPlayerClock">0.00</b></span>
                <span>Chart <b id="debugChartProgress">0/0</b></span>
                <span>Notes <b id="debugActiveNotes">0</b></span>
                <span>Group <b id="debugGroupState">--</b></span>
                <span>Playback <b id="debugPlaybackState">--</b></span>
                <span>Diag <b id="debugDiagState">--</b></span>
                <span id="debugReviewScoreWrap">Review <b id="debugReviewScore">--</b></span>
                <span id="debugReviewStateWrap">Flags <b id="debugReviewState">--</b></span>
            </div>
        </div>
    </div>

    <!-- ── Setup panel ──────────────────────────────────────────────────── -->
    <div id="uploadContainer">
        <h2>Velvet Grid — Rhythm Stage</h2>
        <div class="shell-grid">

            <!-- Left: changelog -->
            <section class="intro-panel">
                <div class="eyebrow">What's New</div>
                <div class="changelog">
                    <div class="cl-entry">
                        <span class="cl-dot new"></span>
                        <div class="cl-text"><b>Result Screen</b> <span class="cl-badge new">new</span><br>
                            Run ends with a full score panel — rank (S/A/B/C/F), accuracy, perfect/good/miss counts, max combo. Hit <b>Enter</b> to replay or <b>Esc</b> to return.
                        </div>
                    </div>
                    <div class="cl-entry">
                        <span class="cl-dot new"></span>
                        <div class="cl-text"><b>Geometry Drag Paths</b> <span class="cl-badge new">new</span><br>
                            Drag notes now trace smooth curved shapes — <b>loop</b>, <b>S-curve</b>, <b>hook</b>, <b>wide arc</b>. All built with cubic bezier, no jagged corners.
                        </div>
                    </div>
                    <div class="cl-entry">
                        <span class="cl-dot new"></span>
                        <div class="cl-text"><b>Rapid-Tap Notes</b> <span class="cl-badge new">new</span><br>
                            Dense beat clusters auto-merge into a single <b>×N</b> burst note. Click or press any key rapidly to clear — speed determines your score.
                        </div>
                    </div>
                    <div class="cl-entry">
                        <span class="cl-dot fix"></span>
                        <div class="cl-text"><b>Keyboard-only Notes</b> <span class="cl-badge fix">fix</span><br>
                            Notes showing a letter key are now strictly keyboard-only. Mouse clicks are blocked — no more accidental easy-clears.
                        </div>
                    </div>
                    <div class="cl-entry">
                        <span class="cl-dot tweak"></span>
                        <div class="cl-text"><b>Drag Tolerance Tuning</b> <span class="cl-badge tweak">tweak</span><br>
                            Polygon path hit-window widened 2.2×. Corner zones get a local 1.5× boost. Progress can skip past tight bends without breaking the chain.
                        </div>
                    </div>
                    <div class="cl-entry">
                        <span class="cl-dot tweak"></span>
                        <div class="cl-text"><b>Responsive Scaling</b> <span class="cl-badge tweak">tweak</span><br>
                            Canvas and note sizes now scale relative to your screen. Feels the same on a laptop as on a large monitor.
                        </div>
                    </div>
                </div>
            </section>

            <!-- Right: controls -->
            <section class="control-panel">
                <div class="control-grid">
                    <div class="control-row">
                        <div class="file-upload wide">
                            <span class="file-upload-btn">Choose Local Audio File</span>
                            <input type="file" id="audioUpload" accept="audio/*">
                        </div>
                    </div>
                    <div class="control-row">
                        <input class="wide" id="youtubeUrl" type="url" placeholder="Paste YouTube URL (<= 6 min)">
                        <select id="difficultySelect">
                            <option value="easy">Easy</option>
                            <option value="normal" selected>Normal</option>
                            <option value="hard">Hard</option>
                        </select>
                        <select id="playModeSelect">
                            <option value="casual" selected>Casual</option>
                            <option value="strict">Strict</option>
                        </select>
                        <select id="analysisStrategySelect">
                            <option value="auto" selected>Auto Strategy</option>
                            <option value="full">Force Full-song</option>
                            <option value="segmented">Force Segmented</option>
                        </select>
                        <select id="chartDensitySelect">
                            <option value="relaxed">Relaxed Density</option>
                            <option value="normal" selected>Normal Density</option>
                            <option value="dense">Dense Density</option>
                        </select>
                    </div>
                    <div class="control-row actions">
                        <button id="analyzeYoutube">Prepare Link Mode</button>
                        <button id="startGame" disabled>Start Game</button>
                        <button id="cancelAnalyze" disabled>Cancel Analysis</button>
                        <button id="pauseGameBtn" disabled>Pause</button>
                        <button id="resumeGameBtn" disabled style="display:none;">Resume</button>
                    </div>
                    <div id="statusText" class="status-panel"></div>
                    <div id="readyPanel" style="display:none;margin-top:10px;">
                        <span id="modeBadge">-</span>
                        <span id="readyBadge">no</span>
                        <span id="notesBadge">-</span>
                        <span id="densityBadge">-</span>
                    </div>
                </div>
            </section>
        </div>
    </div>

    <div id="pauseOverlay" class="hidden">
        <div id="pauseOverlayText">Paused</div>
        <div id="pauseOverlaySubtext" style="font-size:14px;opacity:.8;max-width:420px;text-align:center;">Resume will trigger a short countdown.</div>
        <button id="overlayResumeBtn">Resume Run</button>
    </div>
    <div id="livePlayerHolder" class="hidden">
        <div id="ytPlayer"></div>
        <audio id="liveAudio" playsinline crossorigin="anonymous"></audio>
    </div>

    <script>
    // ── crypto shim ─────────────────────────────────────────────────────
    (function(){
        var c=window.crypto=window.crypto||window.msCrypto||{};
        if(typeof c.randomUUID!=='function'){
            c.randomUUID=function(){
                var b=new Uint8Array(16);
                if(typeof c.getRandomValues==='function')c.getRandomValues(b);
                else for(var i=0;i<b.length;i++)b[i]=Math.floor(Math.random()*256);
                b[6]=(b[6]&15)|64;b[8]=(b[8]&63)|128;
                var h=Array.from(b,function(x){return x.toString(16).padStart(2,'0');});
                return[h.slice(0,4).join(''),h.slice(4,6).join(''),h.slice(6,8).join(''),h.slice(8,10).join(''),h.slice(10,16).join('')].join('-');
            };
        }
    })();

    // ── Loading overlay juice ────────────────────────────────────────────
    (function(){
        var overlay  = document.getElementById('loadingOverlay');
        var waitBar  = document.getElementById('waitBar');
        var waitSub  = document.getElementById('waitSubtext');
        var waitStat = document.getElementById('waitStatus');
        var wCanvas  = document.getElementById('waitCanvas');
        var wCtx     = wCanvas ? wCanvas.getContext('2d') : null;

        var subtexts = [
            'Mapping beats & building chart…',
            'Detecting segment boundaries…',
            'Tuning note density & mechanics…',
            'Placing geometry drag paths…',
            'Running playability audit…',
            'Almost ready — warming up the stage…'
        ];
        var statuses = [
            'Beat detection pass 1/3',
            'Segmentation complete ✦',
            'Mechanic planner running…',
            'Path templates assigned',
            'Collision pass finished',
            'Loading complete'
        ];

        // Particle system
        var particles = [];
        function spawnParticles(x,y,count){
            for(var i=0;i<(count||8);i++){
                var angle=Math.random()*Math.PI*2;
                var speed=Math.random()*2.2+0.6;
                particles.push({
                    x:x,y:y,
                    vx:Math.cos(angle)*speed,vy:Math.sin(angle)*speed,
                    r:Math.random()*3+1,
                    life:1,
                    color:Math.random()>0.5?'rgba(198,163,255,':'rgba(132,241,255,'
                });
            }
        }
        function spawnRandomParticle(){
            if(!wCanvas)return;
            spawnParticles(Math.random()*wCanvas.width,Math.random()*wCanvas.height,1);
        }

        var lastT=0;
        function animLoop(ts){
            if(!overlay.classList.contains('visible'))return;
            if(!wCanvas)return requestAnimationFrame(animLoop);
            var dt=Math.min(60,(ts-lastT))/1000;lastT=ts;
            wCanvas.width=window.innerWidth;wCanvas.height=window.innerHeight;

            // Ambient random sparks
            if(Math.random()<0.06)spawnRandomParticle();

            // Draw particles
            for(var i=particles.length-1;i>=0;i--){
                var p=particles[i];
                p.x+=p.vx;p.y+=p.vy;
                p.vx*=0.96;p.vy*=0.96;
                p.life-=dt*1.1;
                if(p.life<=0){particles.splice(i,1);continue;}
                wCtx.beginPath();
                wCtx.arc(p.x,p.y,p.r*p.life,0,Math.PI*2);
                wCtx.fillStyle=p.color+(p.life*0.9)+')';
                wCtx.fill();
            }
            requestAnimationFrame(animLoop);
        }

        // Click / key sparks
        overlay.addEventListener('click',function(e){
            spawnParticles(e.clientX,e.clientY,18);
            // ripple
            var rip=document.createElement('div');
            rip.className='wait-ripple';
            rip.style.left=e.clientX+'px';
            rip.style.top=e.clientY+'px';
            overlay.appendChild(rip);
            setTimeout(function(){rip.remove();},750);
        });
        document.addEventListener('keydown',function(e){
            if(!overlay.classList.contains('visible'))return;
            var cx=window.innerWidth/2,cy=window.innerHeight/2;
            spawnParticles(cx+Math.random()*200-100,cy+Math.random()*100-50,12);
        });

        // Progress simulation (real progress driven by music-api.js via setWaitProgress)
        var currentPct=0;
        window.setWaitProgress=function(pct,statusText){
            currentPct=Math.max(currentPct,Math.min(100,pct));
            if(waitBar)waitBar.style.width=currentPct+'%';
            if(statusText&&waitStat)waitStat.textContent=statusText;
            // cycle subtext at certain thresholds
            var idx=Math.min(subtexts.length-1,Math.floor(currentPct/17));
            if(waitSub)waitSub.textContent=subtexts[idx];
            if(currentPct>=100&&waitStat)waitStat.textContent='All systems go ✦';
        };
        window.showWaitOverlay=function(msg){
            currentPct=0;
            if(waitBar)waitBar.style.width='0%';
            if(waitSub)waitSub.textContent=subtexts[0];
            if(waitStat)waitStat.textContent=msg||'Initialising…';
            overlay.classList.add('visible');
            requestAnimationFrame(animLoop);
        };
        window.hideWaitOverlay=function(){
            overlay.classList.remove('visible');
        };
    })();
    </script>

    <script src="https://cdn.jsdelivr.net/npm/hls.js@1.5.17/dist/hls.min.js"></script>
    <script src="https://www.youtube.com/iframe_api"></script>
    <script src="rgb-effect.js?v=20260309a"></script>
    <script src="default-songs.js?v=20260307a"></script>
    <script src="music-api.js?v=20260307a"></script>
    <script src="clock-controller.js?v=20260312a"></script>
    <script src="run-orchestrator.js?v=20260312a"></script>
    <script src="chart-runtime.js?v=20260313b"></script>
    <script src="run-completion.js?v=20260312a"></script>
    <script src="playback-controller.js?v=20260312a"></script>
    <script src="chart-policy.js?v=20260319a"></script>
    <script src="chart-reviewer.js?v=20260313c"></script>
    <script src="path-templates.js?v=20260319b"></script>
    <script src="game.js?v=20260319c"></script>
    <script src="youtube-client.js?v=20260311d"></script>
</body>
